+// Browser live-stream stdin: instead of a blocking fread() on a FILE*, pull CU8
+// bytes from the host page's sample queue and suspend the wasm (via JSPI, or
+// Asyncify as a fallback) until data is available. Module.rtl433ReadStdin(len)
+// resolves to a Uint8Array of up to `len` bytes; an empty array means EOF, which
+// we use to stop the decode loop cleanly. See src/decoder.ts on the JS side.
+EM_ASYNC_JS(unsigned long, rtl433_host_read, (uint8_t *buf, unsigned long len), {
+    const chunk = await Module["rtl433ReadStdin"](len);
+    if (!chunk || chunk.length === 0) return 0;
+    HEAPU8.set(chunk, buf);
+    return chunk.length;
+});
+#endif
